# Template for stack.env, which docker-compose reads and which is gitignored.
# Copy it (`cp stack.env.tmpl stack.env`) and fill in the placeholders.
#
# The names here are the explicit `env` tags on the Kong command structs in
# internal/config. Keep the two in sync.

# Interface the server binds. Empty binds every interface.
HOST=0.0.0.0
# Port the server listens on.
PORT=8080

# The PRIVATE metrics listener. /metrics exposes every org and project slug and
# their stored byte counts, so it is deliberately not on the public listener and
# deliberately defaults to loopback. Widening it is an explicit act.
METRICS_ADDR=127.0.0.1:9090

# Serve the API and metrics but not the web console.
HEADLESS=false

# Directory the local storage driver writes blobs to. Local disk only; S3 is
# explicitly deferred.
STORAGE_DIR=/var/lib/bakery

# Postgres.
POSTGRES_USER=bakery
# REQUIRED. Generate one: openssl rand -base64 32
# Left empty on purpose -- the postgres image refuses to initialize without a
# password, so the stack fails closed until you supply a real secret here.
POSTGRES_PASSWORD=
POSTGRES_DB=bakery

# The full Postgres connection string. REQUIRED: the server refuses to start
# without it. Keep the password in lockstep with POSTGRES_PASSWORD above.
DB_URL=postgres://bakery:@db:5432/bakery?sslmode=disable

# Boot takes pg_try_advisory_lock and REFUSES to start a second instance. That
# refusal is what makes the in-process route cache and the single-writer GC sound.
# Setting this to true does not make a second instance correct; it makes it your
# problem. Leave it false unless you are running a controlled rolling deploy.
ALLOW_MULTI_INSTANCE=false

# --- OIDC ---------------------------------------------------------------------
# The `groups` claim answers three of the four authorization planes: the LOGIN GATE
# (may this human use Bakery at all), the OIDC half of the SITE role, and the OIDC
# half of every ORG membership. The other half of the last two is granted in-app,
# and the effective role is the greater of the two. So `groups` is not optional --
# not because every role comes from it, but because a groups claim we cannot READ
# is a REFUSED LOGIN: "the IdP says zero groups" and "we could not read your groups"
# are different facts, and only the first is safe to act on (see groups.example.json).
# `offline_access` buys the refresh token the CLI's device grant needs.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback
OIDC_SCOPES=openid,profile,email,groups,offline_access

# The group map: the LOGIN GATE (`login_groups`), the site-admin groups, and the
# group -> org mapping. A nested document, so it is a FILE, not an env var. See
# groups.example.json. A malformed one is a boot failure, not a warning.
#
# `login_groups` EMPTY OR OMITTED ADMITS ANY SUCCESSFUL OIDC AUTH -- the IdP has
# already decided who may authenticate. `orgs` may be empty or omitted too: org
# membership is hybrid, so a deployment can run entirely on in-app grants and never
# name an org here at all.
#
# SHIPPED COMMENTED OUT ON PURPOSE. When it is empty/unset, boot skips the group
# map entirely (internal/server/boot.go loads it only when non-empty); when it
# points at /etc/bakery/groups.json the server hard-fails on a missing file and,
# under `restart: unless-stopped`, crash-loops forever -- and docker-compose.yaml
# does NOT mount that path by default. So enabling group mapping is one explicit,
# three-part act:
#   1. cp groups.example.json groups.json  (and edit it)
#   2. uncomment the ./groups.json bind mount in docker-compose.yaml
#   3. uncomment the line below
# Do all three or none: setting this without the mount is the crash loop above.
# GROUP_MAP_FILE=/etc/bakery/groups.json

# --- IN-APP GRANTS ------------------------------------------------------------
# Org membership and the site role are HYBRID: an OIDC group claim is one half, an
# in-app grant is the other, and the effective role is the greater of the two. The
# login reconciler writes only the claim half, so it cannot clobber a local grant.
# These two flags govern the local half.

# Let ANY signed-in user create an organization. They become its LOCAL OWNER, in the
# same transaction -- which is what makes the new org usable: create org -> create
# project -> mint a key, with no LDAP round-trip and no cluster admin.
#
# false restricts creation to site admins. It does NOT take the owner grant away:
# an org whose creator holds no membership in it is an org nobody can ever join.
# No API key can reach this endpoint whatever it says -- a delegation must not become
# the master of a brand-new tenant.
ALLOW_SELF_SERVE_ORGS=true

# Let a site admin grant another user the site-admin role through the API, recorded
# with provenance and visible as `local: granted by ...` in the site-admin listing.
#
# false closes that path entirely -- for a deployment that wants the platform-admin
# roster to live in the directory and nowhere else. Revoking an EXISTING local grant
# keeps working when it is false, because turning it off is exactly when an operator
# needs to clean up the grants that predate it.
#
# It does NOT gate `bakery user site-admin <email>`, which writes straight to the
# database and has no HTTP path at all. That is the break-glass: with no login_groups
# and no site_admin_groups, a fresh deployment has no site admin and every path to
# making one requires already being one. It needs DB_URL -- infrastructure access,
# not a session -- and anyone holding that could UPDATE the column by hand anyway.
ALLOW_LOCAL_SITE_ADMINS=true

# --- DEVELOPMENT ONLY ---------------------------------------------------------
# When true, seeds dev@bakery.local as a site admin plus a dev-org/playground
# org and project, and exposes an endpoint that mints a session with NO credential.
# That is a total authentication bypass, which is why it is reachable ONLY from
# this variable or the matching flag: no UI control, no API endpoint and no
# database column can turn it on. NEVER set it in production.
DEV_LOGIN_ENABLED=false
